{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Frontend for IC Vibe application",
  "scripts": {
    "start": "vite --host 0.0.0.0 --port 5173",
    "dev": "concurrently -k \"vite --host 0.0.0.0 --port 5173\" \"chokidar \"../declarations/**/*\" -c \"cd .. && dfx generate\" --initial\"",
    "prebuild": "dfx generate",
    "build": "tsc && vite build",
    "test": "vitest run"
  },
  "dependencies": {
    "@dfinity/auth-client": "^2.4.1",
    "@heroicons/react": "^2.2.0",
    "@react-google-maps/api": "^2.20.3",
    "@vis.gl/react-google-maps": "^1.5.5",
    "@tanstack/react-query": "^5.0.0",
    "bad-words": "^4.0.0",
    "firebase": "^12.3.0",
    "leaflet": "^1.9.4",
    "react": "^19.2.0",
    "react-datepicker": "^8.4.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.7.0",
    "recharts": "^3.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/leaflet": "^1.9.20",
    "@types/node": "^24.7.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^4.0.1",
    "chokidar": "^3.5.3",
    "concurrently": "^8.2.2",
    "dotenv": "^16.3.1",
    "jsdom": "^26.1.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.0.0",
    "vite": "^6.3.6",
    "vitest": "^3.2.4"
  }
}
