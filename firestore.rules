rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read their own profile, admins can read any.
    match /users/{userId} {
      allow read: if request.auth.uid == userId || request.auth.token.isAdmin == true;
      allow write: if request.auth.uid == userId;
    }
    // Services can be read by anyone, but only written by the provider or an admin.
    match /services/{serviceId} {
        allow read: if request.auth != null;
        allow write: if resource.data.providerId == request.auth.uid || request.auth.token.isAdmin == true;
    }
    // Service packages can be read by anyone authenticated, written by provider or admin.
    match /service_packages/{packageId} {
        allow read: if request.auth != null;
        allow write: if resource.data.providerId == request.auth.uid || request.auth.token.isAdmin == true;
    }
    // Bookings can only be read/written by participants or an admin.
    match /bookings/{bookingId} {
        allow read, write: if request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.providerId || request.auth.token.isAdmin == true;
    }
    // Reviews can be created by authenticated users, but not modified.
    match /reviews/{reviewId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if false; // Reviews are immutable
    }
    // Notifications can only be read by the user they belong to or admins.
    match /notifications/{notificationId} {
        allow read: if request.auth.uid == resource.data.userId || request.auth.token.isAdmin == true;
        allow create: if request.auth != null; // Any authenticated user can create notifications
        allow update: if request.auth.uid == resource.data.userId || request.auth.token.isAdmin == true; // Only owner or admin can update
        allow delete: if request.auth.token.isAdmin == true; // Only admins can delete
    }
    // Notification frequency tracking (for spam prevention) - internal use only
    match /notificationFrequency/{freqId} {
        allow read, write: if false; // Only accessible via Cloud Functions
    }
    // Media items can be read by anyone authenticated, but only written/deleted by owner or admin
    match /media/{mediaId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth.uid == resource.data.ownerId || request.auth.token.isAdmin == true;
        allow delete: if request.auth.uid == resource.data.ownerId || request.auth.token.isAdmin == true;
    }
    // User media index - only accessible by the user themselves or admins
    match /users/{userId}/media/{mediaId} {
        allow read: if request.auth.uid == userId || request.auth.token.isAdmin == true;
        allow write: if request.auth.uid == userId || request.auth.token.isAdmin == true;
    }

    // A user can read/write a conversation if they are the client or provider.
    match /conversations/{conversationId} {
      allow create: if request.auth != null;
      allow read, write: if request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.providerId || request.auth.token.isAdmin == true;
    }

    // A user can read messages in a conversation they are part of.
    // A user can create a message if they are the sender.
    match /messages/{messageId} {
      allow read: if ('participants' in resource.data && request.auth.uid in resource.data.participants) || 
                     (!('participants' in resource.data) && (get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.clientId == request.auth.uid ||
                     get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.providerId == request.auth.uid)) ||
                     request.auth.token.isAdmin == true;
      allow create: if request.auth.uid == request.resource.data.senderId && ('participants' in request.resource.data) && (request.auth.uid in request.resource.data.participants);
      allow update: if request.auth.uid == resource.data.receiverId; // For updating read status
      allow delete: if false; // Messages are immutable
    }

    // Reputations can be read by anyone, but only written by the backend (Admin SDK).
    match /reputations/{userId} {
        allow read: if true;
        allow write: if false;
        
        match /history/{historyId} {
            allow read: if true;
            allow write: if false;
        }
    }

    // Default deny all other collections
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
