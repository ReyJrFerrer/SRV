rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.isAdmin == true;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Helper function to validate file size
    function isValidSize(maxSizeInMB) {
      return request.resource.size <= maxSizeInMB * 1024 * 1024;
    }
    
    // Helper function to validate image content type
    function isValidImageType() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType == 'application/pdf';
    }
    
    // Helper function to validate chat attachment content types
    function isValidChatAttachmentType() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType.matches('video/.*') ||
             request.resource.contentType == 'application/pdf' ||
             request.resource.contentType == 'text/plain' ||
             request.resource.contentType == 'text/csv' ||
             request.resource.contentType == 'application/msword' ||
             request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document';
    }
    
    // User profile images - users/{userId}/{mediaId}_{filename}
    match /users/{userId}/{allPaths=**} {
      // Allow public read access (profile pictures should be publicly viewable)
      allow read: if true;
      
      // Allow write only by owner or admin, with size limit (450KB)
      allow write: if (isOwner(userId) || isAdmin()) && 
                      isValidImageType() && 
                      isValidSize(0.45);
      
      // Allow delete only by owner or admin
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    // Service images - services/{providerId}/{mediaId}_{filename}
    match /services/{providerId}/{allPaths=**} {
      // Allow public read access (service images should be publicly viewable)
      allow read: if true;
      
      // Allow write only by owner or admin, with size limit (450KB)
      allow write: if (isOwner(providerId) || isAdmin()) && 
                      isValidImageType() && 
                      isValidSize(0.45);
      
      // Allow delete only by owner or admin
      allow delete: if isOwner(providerId) || isAdmin();
    }
    
    // Service certificates - certificates/{providerId}/{mediaId}_{filename}
    match /certificates/{providerId}/{allPaths=**} {
      // Allow public read access (certificates should be publicly viewable)
      allow read: if true;
      
      // Allow write only by owner or admin, with size limit (450KB)
      allow write: if (isOwner(providerId) || isAdmin()) && 
                      isValidImageType() && 
                      isValidSize(0.45);
      
      // Allow delete only by owner or admin
      allow delete: if isOwner(providerId) || isAdmin();
    }
    
    // Remittance payment proofs - remittance/{userId}/{mediaId}_{filename}
    match /remittance/{userId}/{allPaths=**} {
      // Allow read by owner, admin, or system
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow write only by owner, with larger size limit (1MB for remittance)
      allow write: if isOwner(userId) && 
                      isValidImageType() && 
                      isValidSize(1);
      
      // Allow delete only by owner or admin
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    // Report attachments - reports/{userId}/{mediaId}_{filename}
    match /reports/{userId}/{allPaths=**} {
      // Allow public read access (admins need to view these)
      allow read: if true;
      
      // Allow write only by owner or admin, with size limit (450KB)
      allow write: if (isOwner(userId) || isAdmin()) && 
                      isValidImageType() && 
                      isValidSize(0.45);
      
      // Allow delete only by admin
      allow delete: if isAdmin();
    }
    
    // Chat attachments - chat-attachments/{conversationId}/{mediaId}_{filename}
    match /chat-attachments/{conversationId}/{allPaths=**} {
      // Allow read by authenticated users
      allow read: if isAuthenticated();
      
      // Allow write by authenticated users
      // Images, Videos, Documents: max 1GB
      allow write: if isAuthenticated() && 
                      isValidChatAttachmentType() &&
                      isValidSize(1024);
      
      // Allow delete by authenticated users
      allow delete: if isAuthenticated();
    }
    
    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
